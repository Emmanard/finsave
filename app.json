{
  "expo": {
    "name": "Finsave",
    "slug": "finsave",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "finsave",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#090909"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.finsave.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#090909"
      },
      "package": "com.finsave.app"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "b7f8b3f9-8d8c-4873-ab9c-c0a70d4aae39"
      }
    }
  }
}
